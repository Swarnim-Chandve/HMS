# Use Python 3.10–3.13 (not 3.14 yet for pydantic). Prefer ./run-uv.sh if pacman has no 3.13 package.
# Default SQLite — set DATABASE_URL for PostgreSQL, e.g. postgresql+psycopg2://user:pass@localhost:5432/hms
DATABASE_URL=sqlite:///./hms.db
# openssl rand -hex 32
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
# Seed admin (optional; created if no users exist)
# ADMIN_SEED_EMAIL=admin@example.com
# ADMIN_SEED_PASSWORD=Admin123!
CORS_ORIGINS=*
